# TermSync server environment variables
# Copy this file to .env and adjust values as needed.

# HTTPS / WSS port
TERMSYNC_PORT=7373

# HTTP redirect port
TERMSYNC_HTTP_PORT=8080

# SQLite database path
TERMSYNC_DB_PATH=./data/termsync.db

# JWT signing secret
TERMSYNC_JWT_SECRET=change-this-to-a-random-secret
